#include "../zmk-nodefree-config/keypos_def/keypos_42keys.h"

skq: sticky_key_quick_release {
  compatible = "zmk,behavior-sticky-key";
  label = "STICKY_KEY_QUICK_RELEASE";
  #binding-cells = <1>;
  bindings = <&kp>;
  quick-release;
  release-after-ms = <STICKY_KEY_TIMEOUT>;
};

// Sticky key on tap, normal key on hold
// Useful for modifier-clicking without the modifier remaining active
nk: not_so_sticky_key {
  compatible = "zmk,behavior-hold-tap";
  label = "NOT_SO_STICKY_KEY";
  #binding-cells = <2>;
  tapping_term_ms = <200>;
  flavor = "tap-preferred";
  bindings = <&kp>, <&sk>;
};

// A hold-tap that activates without delay (like `&mo`)
mo_tap: mo_with_tap {
  compatible = "zmk,behavior-hold-tap";
  label = "MO_WITH_TAP";
  #binding-cells = <2>;
  tapping_term_ms = <0>;
  retro-tap;
  flavor = "hold-preferred";
  bindings = <&mo>, <&kp>;
};

u_mt: u_mt {
  compatible = "zmk,behavior-hold-tap";
  label = "u_mt";
  #binding-cells = <2>;
  tapping_term_ms = <U_TAPPING_TERM>;
  flavor = "tap-preferred";
  bindings = <&kp>, <&kp>;
};

    
u_lt: u_lt {
  compatible = "zmk,behavior-hold-tap";
  label = "u_lt";
  #binding-cells = <2>;
  tapping_term_ms = <U_TAPPING_TERM>;
  flavor = "tap-preferred";
  bindings = <&mo>, <&kp>;
};

u_td: u_td {
    compatible = "zmk,behavior-tap-dance";
    label = "u_td";
    #binding-cells = <0>;
    tapping-term-ms = <200>;
    bindings = <&kp COLON>, <&kp SEMI>;
};


#define KEYS_L LT0 LT1 LT2 LT3 LT4 LT5 LM0 LM1 LM2 LM3 LM4 LM5 LB0 LB1 LB2 LB3 LB4 LB5 // left-hand keys
#define KEYS_R RT0 RT1 RT2 RT3 RT4 RT5 RM0 RM1 RM2 RM3 RM4 LM5 RB0 RB1 RB2 RB3 RB4 LB5 // right-hand keys
#define THUMBS LH2 LH1 LH0 RH0 RH1 RH2                                      // thumb keys

hm_l: homerow_mods_quick_left {
  compatible = "zmk,behavior-hold-tap";
  label = "HOMEROW_MODS_QUICK";
  flavor = "balanced";
  tapping-term-ms = <280>;                        // <---[[produces tap if held longer than tapping-term-ms]]
  quick-tap-ms = <125>;
  #binding-cells = <2>;
  bindings = <&kp>, <&kp>;
};
hm_r: homerow_mods_quick_right {
  compatible = "zmk,behavior-hold-tap";
  label = "HOMEROW_MODS_QUICK";
  flavor = "balanced";
  tapping-term-ms = <280>;                        // <---[[produces tap if held longer than tapping-term-ms]]
  quick-tap-ms = <125>;
  #binding-cells = <2>;
  bindings = <&kp>, <&kp>;
};

