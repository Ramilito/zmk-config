compatible = "zmk,keymap";

base_layer {
  label = "BASE";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
           SK(LALT)          &kp Q            &kp W           &kp F            &kp P            &kp B                    &kp J            &kp L            &kp U            &kp Y           &kp SQT         SK(LGUI) 
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
           SK(LCTRL)         &kp A            &kp R           &kp S            &kp T            &kp G                    &kp M            &kp N            &kp E            &kp I           &kp O          
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
           SK(LSHIFT)        &kp Z            &kp X           &kp C            &kp D            &kp V                    &kp K            &kp H            &kp COMMA        &kp DOT         &kp SLASH       SK(LSHIFT) 
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                         U_LT(MEDIA, ESC) U_LT(NAV, SPACE) U_LT(MOUSE, TAB)          U_LT(SYM, ENTER)  U_LT(NUM, BSPC)   U_LT(FUN, DEL)
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

nav_layer {
  label = "NAV";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX         &kp LS(LC(W))  &kp LS(LC(LEFT)) &kp LS(LC(DOWN))  &kp LS(LC(UP))  &kp LS(LC(RIGHT))      &kp LG(LC(LA(LEFT))) &kp LC(TAB)   &kp LC(LS(TAB)) &kp LG(LC(LA(RIGHT)))  XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX        &kp LC(KP_PLUS)  &kp LC(MINUS)         XXX             XXX                     &kp LEFT         &kp DOWN          &kp UP          &kp RIGHT          XXX           &caps_word 
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX     &kp LS(LA((PLUS))) &kp LS(LA((MINUS)))    XXX             XXX                      XXX             &kp PG_DN        &kp PG_UP        &kp END          &kp INS            XXX 
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                              ___               ___             ___                    &kp ENTER        &kp BSPC           ___
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

sym_layer {
  label = "SYM";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX           &kp TILDE       &kp LBKT         &kp AMPS         &kp RBKT           XXX                      XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX           &kp CRRT        &kp LBRC         &kp DLLR         &kp RBRC         &kp PLUS                   XXX            &kp COLON        &kp SEMI           XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX           &kp EXCL        &kp LPAR         &kp AT           &kp RPAR         &kp PIPE                   XXX              XXX              XXX              XXX              XXX              XXX
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                               ___            &kp SPACE        &kp UNDER                  ___              ___              ___
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

num_layer {
  label = "NUM";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX             XXX           &kp NUM_7       &kp NUM_8        &kp NUM_9          XXX                      XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX           &kp NUM_4       &kp NUM_5        &kp NUM_6         &kp EQL                   XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX           &kp GRAVE       &kp NUM_1       &kp NUM_2        &kp NUM_3        &kp BSLH                   XXX              XXX              XXX              XXX              XXX              XXX
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                              ___            &kp NUM_0        &kp MINUS                  ___              ___              ___
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

media_layer {
  label = "MEDIA";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX             XXX             XXX             XXX              XXX              XXX                      XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX             XXX             XXX              XXX              XXX                      XXX           &kp C_VOL_DN     &kp C_VOL_UP        XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX             XXX             XXX              XXX              XXX                      XXX           &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3      &bt BT_CLR
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                              ___               ___             ___                      ___              ___            &kp C_MUTE
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

