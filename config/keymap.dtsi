compatible = "zmk,keymap";

base_layer {
  label = "BASE";
  bindings = <
    // ╭─────────────┬────────────┬────────────┬─────────────┬─────────────┬─────────────╮       ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
         &caps_word    &kp Q        &kp W         &kp F         &kp P        &kp B                 &kp J         &kp L         &kp U         &kp Y         &kp SQT        XXX
    // ├─────────────┼────────────┼────────────┼─────────────┼─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         &skq LSHFT    &kp A        &kp R         &kp S         &kp T        &kp G                 &kp M         &kp N         &kp E         &kp I         &kp O          XXX
    // ├─────────────┼────────────┼────────────┼─────────────┼─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
         XXX           &kp Z        &kp X         &kp C         &kp D        &kp V                 &kp K         &kp H         &kp COMMA     &kp DOT       &kp SLASH      XXX
    // ╰─────────────┴────────────┴────────────┴─────────────┴─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┴─────────────┴─────────────┴─────────────╯
                                                  &kp ESC      &lt NAV SPACE &kp TAB               &kp ENTER     MO(NUM)       &kp DEL
    //                                         ╰─────────────┴─────────────┴─────────────╯       ╰─────────────┴─────────────┴─────────────╯
  >;
};

nav_layer {
  label = "NAV";
  bindings = <
    // ╭─────────────┬────────────┬────────────┬─────────────┬─────────────┬─────────────╮       ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
          XXX           XXX         &key_repeat   XXX            XXX         XXX                   XXX           &kp LS(TAB)   &kp TAB       XXX           XXX            XXX
    // ├─────────────┼────────────┼────────────┼─────────────┼─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
          XXX           SK(LGUI)    SK(LALT)      SK(LCTRL)     SK(LSHIFT)   XXX                   &kp LEFT      &kp DOWN      &kp UP        &kp RIGHT     XXX            XXX
    // ├─────────────┼────────────┼────────────┼─────────────┼─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
          XXX           XXX         XXX           XXX           XXX          XXX                   &kp COMMA     &kp DEL       &kp BSPC      &kp ENTER     XXX            XXX
    // ╰─────────────┴────────────┴────────────┴─────────────┴─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┴─────────────┴─────────────┴─────────────╯
                                                   ___           ___          ___                  ___           ___          ___
    //                                         ╰─────────────┴─────────────┴─────────────╯       ╰─────────────┴─────────────┴─────────────╯
  >;
};

num_layer {
  label = "NUM";
  bindings = <

    // ╭─────────────┬────────────┬────────────┬─────────────┬─────────────┬─────────────╮       ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
          XXX          &kp GRAVE     &kp N7        &kp N8        &kp N9        &kp EQUAL           XXX           XXX           XXX           &key_repeat   XXX            XXX
    // ├─────────────┼────────────┼────────────┼─────────────┼─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
          XXX          &kp N0        &kp N4        &kp N5        &kp N6        &kp MINUS           XXX           SK(LSHIFT)    SK(LCTRL)     SK(LALT)      SK(LGUI)       XXX
    // ├─────────────┼────────────┼────────────┼─────────────┼─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
          XXX          &kp BSLH      &kp N1        &kp N2        &kp N3        &kp SEMI            XXX           &kp COLON     XXX           XXX           XXX            XXX
    // ╰─────────────┴────────────┴────────────┴─────────────┴─────────────┼─────────────┤       ├─────────────┼─────────────┼─────────────┴─────────────┴─────────────┴─────────────╯
                                                   ___           ___          ___                  ___           ___          ___
    //                                         ╰─────────────┴─────────────┴─────────────╯       ╰─────────────┴─────────────┴─────────────╯
  >;
};
