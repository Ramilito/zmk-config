compatible = "zmk,keymap";

base_layer {
  label = "BASE";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
           SK(LALT)          &kp Q            &kp W           &kp F            &kp P            &kp B                    &kp J            &kp L            &kp U            &kp Y           &kp SQT       &swe_one_morph 
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
           SK(LCTRL)         &kp A            &kp R           &kp S            &kp T            &kp G                    &kp M            &kp N            &kp E            &kp I           &kp O         &swe_two_morph 
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
           SK(LGUI)          &kp Z            &kp X           &kp C            &kp D            &kp V                    &kp K            &kp H            &kp COMMA        &kp DOT         &kp SLASH     &swe_three_morph 
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                         U_LT(MEDIA, ESC) U_LT(NAV, SPACE) U_MT(LSHIFT,TAB)        U_MT(HYP,ENTER)    U_LT(SYM, BSPC)  U_LT(NUM, DEL)
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

nav_layer {
  label = "NAV";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX             XXX             XXX             XXX              XXX              XXX                    &kp LA(TAB)     &kp LC(TAB)    &kp LC(LS(TAB))      XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX             XXX             XXX              XXX              XXX                    &kp LEFT         &kp DOWN          &kp UP          &kp RIGHT          XXX           &caps_word 
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX             XXX             XXX              XXX              XXX                      XXX            &kp PG_DN        &kp PG_UP        &kp END          &kp INS            XXX 
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                              ___               ___             ___                    &kp ENTER        &kp BSPC           ___
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

sym_layer {
  label = "SYM";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX             XXX          &kp LBKT         &kp AMPS         &kp RBKT           XXX                      XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX          &kp LBRC         &kp DLLR         &kp RBRC           XXX                      XXX            &kp COLON        &kp SEMI           XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX          &kp LPAR         &kp AT           &kp RPAR         &kp PIPE                   XXX              XXX              XXX              XXX              XXX              XXX
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                              ___            &kp SPACE        &kp TAB                    ___              ___              ___
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

num_layer {
  label = "NUM";
  bindings = <
    // ╭────────────────┬───────────────┬───────────────┬────────────────┬────────────────┬────────────────╮       ╭────────────────┬────────────────┬────────────────┬────────────────┬────────────────┬────────────────╮
              XXX             XXX           &kp NUM_7       &kp NUM_8        &kp NUM_9          XXX                      XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX           &kp NUM_4       &kp NUM_5        &kp NUM_6         &kp EQL                   XXX              XXX              XXX              XXX              XXX              XXX
    // ├────────────────┼───────────────┼───────────────┼────────────────┼────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┼────────────────┼────────────────┼────────────────┤
              XXX             XXX           &kp NUM_1       &kp NUM_2        &kp NUM_3          XXX                      XXX              XXX              XXX              XXX              XXX              XXX
    // ╰────────────────┴───────────────┴───────────────┴────────────────┴────────────────┼────────────────┤       ├────────────────┼────────────────┼────────────────┴────────────────┴────────────────┴────────────────╯
                                                              ___            &kp NUM_0        &kp MINUS                  ___              ___              ___
    //                                                  ╰────────────────┴────────────────┴────────────────╯       ╰────────────────┴────────────────┴────────────────╯
  >;
};

