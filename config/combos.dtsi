compatible = "zmk,combos";

#define COMBO(NAME, BINDINGS, KEYPOS, LAYERS) \
  combo_##NAME { \
    bindings = <BINDINGS>; \
    key-positions = <KEYPOS>; \
    layers = <LAYERS>; \
}; 

/* COMBO(shift, &skq LSHFT, 37 40, BASE) */
COMBO(left_parenthesis, &kp LEFT_PARENTHESIS, 1 2, NUM)

